<?xml version="1.0"?>
<robot name="p3_minimal_arm">
  <link name="base">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="20.0"/>
      <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.35 0.25 0.35"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.35 0.25 0.35"/></geometry>
    </collision>
  </link>

  <link name="link_1">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <origin xyz="0.45 0 0" rpy="0 0 0"/>
      <geometry><box size="0.90 0.12 0.16"/></geometry>
    </visual>
    <collision>
      <origin xyz="0.45 0 0" rpy="0 0 0"/>
      <geometry><box size="0.90 0.12 0.16"/></geometry>
    </collision>
  </link>

  <link name="link_2">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.04"/>
    </inertial>
    <visual>
      <origin xyz="0.45 0 0" rpy="0 0 0"/>
      <geometry><box size="0.90 0.10 0.14"/></geometry>
    </visual>
    <collision>
      <origin xyz="0.45 0 0" rpy="0 0 0"/>
      <geometry><box size="0.90 0.10 0.14"/></geometry>
    </collision>
  </link>

  <link name="tool">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0.20 0 0" rpy="0 0 0"/>
      <geometry><box size="0.40 0.20 0.20"/></geometry>
    </visual>
    <collision>
      <origin xyz="0.20 0 0" rpy="0 0 0"/>
      <geometry><box size="0.40 0.20 0.20"/></geometry>
    </collision>
  </link>

  <joint name="base_to_link_1" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base"/>
    <child link="link_1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8" upper="1.2" effort="80" velocity="2.5"/>
  </joint>

  <joint name="link_1_to_link_2" type="revolute">
    <origin xyz="0.9 0 0" rpy="0 0 0"/>
    <parent link="link_1"/>
    <child link="link_2"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.2" upper="2.9" effort="80" velocity="2.5"/>
  </joint>

  <joint name="link_2_to_tool" type="fixed">
    <origin xyz="0.65 0 0" rpy="0 0 0"/>
    <parent link="link_2"/>
    <child link="tool"/>
  </joint>
</robot>
