    setpoint : REAL;
END_VAR
VAR_OUTPUT
    status : INT;
    actual : REAL;
END_VAR
VAR
    counter : DINT;
    integrator : REAL;
    state : INT;
    buf : ARRAY[0..9] OF REAL;
END_VAR

CASE state OF
    0: (* Idle *)
        IF enable THEN
            state := 1;
            counter := 0;
            integrator := 0.0;
        END_IF
    1: (* Running *)
        counter := counter + 1;
        integrator := integrator + setpoint * 0.01;
        IF integrator > 100.0 THEN
            integrator := 100.0;
        ELSIF integrator < -100.0 THEN
            integrator := -100.0;
        END_IF
        actual := integrator;
        buf[counter MOD 10] := actual;
        IF counter > 1000 THEN
            state := 2;
        END_IF
    2: (* Done *)
        status := 1;
        IF NOT enable THEN
            state := 0;
            status := 0;
        END_IF
END_CASE

