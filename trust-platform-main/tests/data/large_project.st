    x : UDINT;
END_VAR
VAR
    i, j : DINT;
    tmp : REAL;
END_VAR

tmp := x;
FOR i := 1 TO 10 DO
    tmp := tmp + 1;
    IF tmp > 1000 THEN
        tmp := 0;
    END_IF
END_FOR
Calc_799 := tmp;
END_FUNCTION


FUNCTION_BLOCK FB_0
VAR_INPUT
    enable : BOOL;
    setpoint : REAL;
END_VAR
VAR_OUTPUT
    status : INT;
    actual : REAL;
END_VAR
VAR
    counter : DINT;
    integrator : REAL;
    state : INT;
    buf : ARRAY[0..9] OF REAL;
END_VAR

CASE state OF
    0: (* Idle *)
        IF enable THEN
            state := 1;
            counter := 0;
            integrator := 0.0;
        END_IF
    1: (* Running *)
        counter := counter + 1;
        integrator := integrator + setpoint * 0.01;
        IF integrator > 100.0 THEN
            integrator := 100.0;
        ELSIF integrator < -100.0 THEN
            integrator := -100.0;
        END_IF
        actual := integrator;
        buf[counter MOD 10] := actual;
        IF counter > 1000 THEN
            state := 2;
        END_IF
    2: (* Done *)
        status := 1;
        IF NOT enable THEN
            state := 0;
            status := 0;
        END_IF
END_CASE

METHOD GetMax_0 : REAL
VAR_INPUT
    a, b : REAL;
END_VAR
VAR
    result : REAL;
END_VAR

IF a > b THEN
    result := a;
ELSE
    result := b;
END_IF
GetMax_0 := result;
END_METHOD

